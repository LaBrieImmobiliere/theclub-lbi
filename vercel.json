{
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm ci",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/relances",
      "schedule": "0 9 */2 * *"
    },
    {
      "path": "/api/cron/relance",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/weekly-recap",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/backup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "0 10 * * 1"
    }
  ]
}
